{
  "manifest_version": 3,
  "name": "Oktha Dev FB Auto Add Friend",
  "version": "1.0",
  "description": "Auto add friend with delay",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["https://*.facebook.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.facebook.com/*"],
      "js": ["content.js"]
    }
  ]
}